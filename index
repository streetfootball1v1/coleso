<!DOCTYPE html>
<html>
<head>
    <title>Колесо Фортуны для Розыгрыша</title>
    <meta charset="utf-8">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.9.1/gsap.min.js"></script>
    <script src="https://raw.githubusercontent.com/zarocknz/javascript-winwheel/master/Winwheel.min.js"></script>
    <style>
        body { font-family: sans-serif; text-align: center; background: #f4f4f9; padding: 20px; }
        .canvas-container { position: relative; display: inline-block; }
        #canvas { background: #fff; border-radius: 50%; box-shadow: 0 0 20px rgba(0,0,0,0.2); }
        .pointer {
            position: absolute; top: -20px; left: 50%; transform: translateX(-50%);
            width: 40px; z-index: 10;
        }
        button {
            margin-top: 20px; padding: 15px 30px; font-size: 18px;
            background: #ff4757; color: white; border: none; border-radius: 25px;
            cursor: pointer; box-shadow: 0 4px 10px rgba(255, 71, 87, 0.3);
        }
        button:active { transform: scale(0.95); }
    </style>
</head>
<body>

    <h2>🎉 Розыгрыш для любимых клиентов</h2>
    
    <div class="canvas-container">
        <div class="pointer">▼</div>
        <canvas id="canvas" width="400" height="400">
            Canvas not supported, use another browser.
        </canvas>
    </div>

    <br>
    <button id="spin_button" onClick="startSpin();">КРУТИТЬ КОЛЕСО!</button>

    <script>
        // Данные участников (потом бот будет подставлять их сюда автоматически)
        let participants = [
            {'fillStyle' : '#eae56f', 'text' : 'Мария'},
            {'fillStyle' : '#89f26e', 'text' : 'Алексей'},
            {'fillStyle' : '#7de6ef', 'text' : 'Елена'},
            {'fillStyle' : '#e7706f', 'text' : 'Дмитрий'},
            {'fillStyle' : '#b19cd9', 'text' : 'Оксана'},
            {'fillStyle' : '#ffcccb', 'text' : 'Иван'}
        ];

        // Создаем колесо
        let theWheel = new Winwheel({
            'canvasId'    : 'canvas',
            'numSegments' : participants.length,
            'outerRadius' : 170,
            'textFontSize' : 18,
            'segments'    : participants,
            'animation' : {
                'type'     : 'spinToStop',
                'duration' : 5,     // Длительность в секундах
                'spins'    : 8,     // Количество полных оборотов
                'callbackFinished' : alertPrize
            }
        });

        function startSpin() {
            theWheel.startAnimation();
        }

        function alertPrize(indicatedSegment) {
            alert("Поздравляем! Победитель: " + indicatedSegment.text);
            theWheel.stopAnimation(false);
            theWheel.rotationAngle = 0; // Сброс для следующего раза
            theWheel.draw();
        }
    </script>
</body>
</html>
